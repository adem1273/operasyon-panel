{
  "name": "vipflow-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @vipflow/api run start:dev",
    "dev:web": "npm --workspace @vipflow/web run dev",
    "build:api": "npm --workspace @vipflow/api run build",
    "build:web": "npm --workspace @vipflow/web run build",
    "lint:api": "npm --workspace @vipflow/api run lint",
    "prisma:generate": "npm --workspace @vipflow/api run prisma:generate",
    "prisma:migrate": "npm --workspace @vipflow/api run prisma:migrate"
  }
}
